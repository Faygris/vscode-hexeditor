{
  "name": "hexeditorfay",
  "displayName": "%name%",
  "description": "%description%",
  "version": "1.11.1",
  "aiKey": "0c6ae279ed8443289764825290e4f9e2-1a736e7c-1324-4338-be46-fc2a58ae4d14-7255",
  "publisher": "ms-vscode",
  "repository": {
    "type": "git",
    "url": "https://github.com/Faygris/vscode-hexeditor"
  },
  "bugs": {
    "url": "https://github.com/Faygris/vscode-hexeditor/issues"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.89.0-insider"
  },
  "categories": [
    "Other"
  ],
  "icon": "icon.png",
  "activationEvents": [],
  "main": "./dist/extension.js",
  "browser": "./dist/web/extension.js",
  "l10n": "./l10n",
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    },
    "virtualWorkspaces": true
  },
  "contributes": {
    "configuration": [
      {
        "title": "%name%",
        "properties": {
          "hexeditorfay.inspectorType": {
            "type": "string",
            "enum": [
              "aside",
              "hover",
              "sidebar"
            ],
            "default": "aside",
            "description": "%hexeditorfay.inspectorType%"
          },
          "hexeditorfay.maxFileSize": {
            "type": "number",
            "minimum": 0,
            "default": 10,
            "description": "%hexeditorfay.maxFileSize%"
          },
          "hexeditorfay.dataInspector.autoReveal": {
            "type": "boolean",
            "default": true,
            "description": "%hexeditorfay.dataInspector.autoReveal%"
          },
          "hexeditorfay.defaultEndianness": {
            "type": "string",
            "default": "little",
            "enum": [
              "little",
              "big"
            ],
            "description": "%hexeditorfay.defaultEndianness%"
          },
          "hexeditorfay.columnWidth": {
            "type": "integer",
            "default": 16,
            "minimum": 1,
            "maximum": 512,
            "description": "%hexeditorfay.columnWidth%"
          },
          "hexeditorfay.copyType": {
            "type": "string",
            "enum": [
              "Hex Octets",
              "Hex",
              "Literal",
              "UTF-8",
              "C",
              "Go",
              "Java",
              "JSON",
              "Base64"
            ],
            "default": "Hex Octets",
            "description": "%hexeditorfay.copyType%"
          },
          "hexeditorfay.showDecodedText": {
            "type": "boolean",
            "default": true,
            "description": "%hexeditorfay.showDecodedText%"
          },
          "hexeditorfay.showOpenFileButton": {
            "type": "boolean",
            "default": false,
            "description": "%hexeditorfay.showOpenFileButton%"
          }
        }
      }
    ],
    "configurationDefaults": {
      "workbench.editorAssociations": {
        "{hexdiff}:/**/*.*": "hexEditorFay.hexedit"
      }
    },
    "customEditors": [
      {
        "viewType": "hexEditorFay.hexedit",
        "displayName": "%name%",
        "selector": [
          {
            "filenamePattern": "*"
          }
        ],
        "priority": "option"
      }
    ],
    "commands": [
      {
        "command": "hexEditorFay.openFile",
        "category": "%name%",
        "title": "%hexEditorFay.openFile%",
        "icon": "$(file-binary)"
      },
      {
        "command": "hexEditorFay.goToOffset",
        "category": "%name%",
        "title": "%hexEditorFay.goToOffset%"
      },
      {
        "command": "hexEditorFay.selectBetweenOffsets",
        "category": "%name%",
        "title": "%hexEditorFay.selectBetweenOffsets%"
      },
      {
        "command": "hexEditorFay.copyAs",
        "category": "%name%",
        "title": "%hexEditorFay.copyAs%"
      },
      {
        "command": "hexEditorFay.switchEditMode",
        "category": "%name%",
        "title": "%hexEditorFay.switchEditMode%"
      },
      {
        "command": "hexEditorFay.copyOffsetAsHex",
        "category": "%name%",
        "title": "%hexEditorFay.copyOffsetAsHex%"
      },
      {
        "command": "hexEditorFay.copyOffsetAsDec",
        "category": "%name%",
        "title": "%hexEditorFay.copyOffsetAsDec%"
      },
      {
        "command": "hexEditorFay.compareSelected",
        "category": "%name%",
        "title": "%hexEditorFay.compareSelected%"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "hexExplorer",
          "title": "%name%",
          "icon": "panel-icon.svg",
          "when": "hexEditorFay:showSidebarInspector"
        }
      ]
    },
    "views": {
      "hexExplorer": [
        {
          "type": "webview",
          "id": "hexEditorFay.dataInspectorView",
          "name": "%dataInspectorView%",
          "when": "hexEditorFay:showSidebarInspector"
        }
      ]
    },
    "menus": {
      "commandPalette": [
        {
          "command": "hexEditorFay.goToOffset",
          "when": "hexEditorFay:isActive"
        },
        {
          "command": "hexEditorFay.switchEditMode",
          "when": "hexEditorFay:isActive"
        },
        {
          "command": "hexEditorFay.compareSelected",
          "when": "false"
        }
      ],
      "editor/title": [
        {
          "command": "hexEditorFay.openFile",
          "group": "navigation@1",
          "when": "activeEditor && config.hexeditorfay.showOpenFileButton"
        }
      ],
      "webview/context": [
        {
          "command": "hexEditorFay.copyOffsetAsDec",
          "group": "9_cutcopypaste",
          "when": "hexEditorFay:isActive"
        },
        {
          "command": "hexEditorFay.copyOffsetAsHex",
          "group": "9_cutcopypaste",
          "when": "hexEditorFay:isActive"
        },
        {
          "when": "webviewId == 'hexEditorFay.hexedit'",
          "command": "hexEditorFay.copyAs",
          "group": "9_cutcopypaste"
        }
      ],
      "explorer/context": [
        {
          "command": "hexEditorFay.compareSelected",
          "group": "3_compare@30",
          "when": "listDoubleSelection"
        }
      ]
    },
    "keybindings": [
      {
        "command": "hexEditorFay.goToOffset",
        "key": "ctrl+g",
        "when": "activeCustomEditorId == hexEditorFay.hexedit"
      },
      {
        "command": "hexEditorFay.copyAs",
        "key": "alt+ctrl+c",
        "when": "activeCustomEditorId == hexEditorFay.hexedit"
      },
      {
        "command": "hexEditorFay.switchEditMode",
        "key": "Insert",
        "when": "hexEditorFay:isActive"
      }
    ]
  },
  "scripts": {
    "compile": "tsc --noEmit && node .esbuild.config.js",
    "lint": "eslint src",
    "fmt": "prettier --write \"{src,media,shared}/**/*.{ts,tsx}\" && npm run lint -- --fix",
    "watch": "node .esbuild.config.js --watch",
    "test": "tsc --noEmit && node ./src/test/runTest.js"
  },
  "devDependencies": {
    "@types/chai": "^5",
    "@types/diff": "^5.2.1",
    "@types/mocha": "^10",
    "@types/node": "^22",
    "@types/react": "^17.0.38",
    "@types/react-dom": "^17.0.11",
    "@types/vscode": "^1.89.0",
    "@vscode/test-electron": "^2.5.2",
    "chai": "^6",
    "esbuild": "^0.25",
    "esbuild-css-modules-plugin": "^3.1.0",
    "esbuild-plugin-svgr": "^3",
    "eslint": "^9",
    "globals": "^16",
    "mocha": "^11.1.0",
    "prettier": "^3.2.4",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.6",
    "@vscode/codicons": "0.0.27",
    "@vscode/extension-telemetry": "^1.5.1",
    "cockatiel": "^3.1.2",
    "diff": "^8.0.3",
    "js-base64": "^3.7.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-popper": "^2.3.0",
    "recoil": "^0.7.7",
    "vscode-webview-tools": "^0.1.1"
  },
  "prettier": {
    "printWidth": 100,
    "tabWidth": 2,
    "arrowParens": "avoid"
  }
}
